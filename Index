<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <title>Company Greenhouse</title>
  <meta name="viewport" content="width=device-width, initial-scale=1" />

  <!-- Fonts -->
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600&family=Playfair+Display:wght@500;700&display=swap" rel="stylesheet">

  <style>
    :root {
      --bg: #F4F7F3;
      --green: #2F6F4E;
      --sage: #A8C3A1;
      --earth: #C9B89B;
      --text: #1F2933;
    }

    * { box-sizing: border-box; }

    body {
      margin: 0;
      background: var(--bg);
      font-family: Inter, sans-serif;
      color: var(--text);
    }

    header {
      padding: 32px 48px;
    }

    h1 {
      font-family: "Playfair Display", serif;
      font-size: 40px;
      margin: 0;
      color: var(--green);
    }

    .subtitle {
      color: #6b7280;
      margin-top: 6px;
    }

    .grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
      gap: 24px;
      padding: 32px 48px;
    }

    .card {
      background: white;
      border-radius: 18px;
      padding: 24px;
      box-shadow: 0 10px 25px rgba(0,0,0,0.06);
      transition: transform 0.2s ease, box-shadow 0.2s ease;
    }

    .card:hover {
      transform: translateY(-4px);
      box-shadow: 0 16px 40px rgba(0,0,0,0.08);
    }

    .card h2 {
      font-family: "Playfair Display", serif;
      margin-top: 0;
      color: var(--green);
    }

    .metric {
      font-size: 36px;
      font-weight: 600;
      margin-top: 12px;
    }

    .label {
      color: #6b7280;
      font-size: 14px;
    }
  </style>
</head>

<body>

<header>
  <h1>Company Greenhouse 🌿</h1>
  <div class="subtitle">Live performance & weekly pulse</div>
</header>

<section class="grid">
  <div class="card">
    <h2>Weekly Sales</h2>
    <div class="metric" id="weeklySales">$0</div>
    <div class="label">Updated live</div>
  </div>

  <div class="card">
    <h2>Month‑to‑Date</h2>
    <div class="metric" id="mtd">$0</div>
    <div class="label">All teams</div>
  </div>

  <div class="card">
    <h2>Year‑to‑Date</h2>
    <div class="metric" id="ytd">$0</div>
    <div class="label">Company total</div>
  </div>
</section>

<script>
  // Mock live updates (replace with Supabase/Firebase later)
  setInterval(() => {
    document.getElementById("weeklySales").innerText =
      "$" + (20000 + Math.floor(Math.random() * 5000)).toLocaleString();

    document.getElementById("mtd").innerText =
      "$" + (120000 + Math.floor(Math.random() * 10000)).toLocaleString();

    document.getElementById("ytd").innerText =
      "$" + (980000 + Math.floor(Math.random() * 25000)).toLocaleString();
  }, 2000);
</script>

</body>
</html>
